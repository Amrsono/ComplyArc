# ============================================
# Cortex AML — Environment Configuration
# ============================================

# Database
DATABASE_URL=postgresql+asyncpg://cortex:cortex_secret@localhost:5432/cortex_aml
DATABASE_URL_SYNC=postgresql://cortex:cortex_secret@localhost:5432/cortex_aml

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# API Keys
API_KEY_HEADER=X-API-Key

# OpenAI (for adverse media AI analysis)
OPENAI_API_KEY=sk-your-openai-api-key

# News API (for adverse media monitoring)
NEWS_API_KEY=your-news-api-key

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Environment
ENVIRONMENT=development
DEBUG=true
