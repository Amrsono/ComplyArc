{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "apps/api/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "apps/api/api/index.py"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "apps/web/$1"
    }
  ]
}
